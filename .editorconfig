# EditorConfig is awesome: https://editorconfig.org

root = true

# Global settings (applies to all files unless overridden)
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4
max_line_length = 100

# Markdown — trailing whitespace creates <br> line breaks
[*.md]
trim_trailing_whitespace = false
indent_size = 2

# YAML — standard convention is 2-space indent
[*.{yaml,yml}]
indent_size = 2

# Move-specific settings
[*.move]
indent_size = 4
