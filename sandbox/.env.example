# DeepBook Sandbox Environment Variables
# Copy this file to .env and customize as needed
#
# Quick start: cp .env.example .env && pnpm install && pnpm deploy-all

# Private key for the deployer/signer (suiprivkey1... or 0x... hex).
# Required for deployment and pool creation.
# Export your active address key with:
#   sui keytool export --key-identity $(sui client active-address)
PRIVATE_KEY=

# Oracle service keypair (auto-generated by deploy-all for localnet).
# The oracle service uses a separate keypair so it doesn't compete for gas
# coins with the market maker / deployer.
# ORACLE_PRIVATE_KEY=

# =============================================================================
# Sui Localnet (only needed if using --profile localnet)
# =============================================================================
# Set based on your CPU architecture:
#   ARM64 (Apple Silicon M1/M2/M3/M4): mysten/sui-tools:compat-arm64
#   x86_64 (Intel/AMD):                mysten/sui-tools:compat
SUI_TOOLS_IMAGE=mysten/sui-tools:compat-arm64

# Wipe chain state on every restart (default: true)
# Set to empty to persist state across restarts
FORCE_REGENESIS=true

# =============================================================================
# Network Configuration
# =============================================================================
# Sui RPC endpoint URL (optional — defaults to http://127.0.0.1:9000 for localnet)
# Only set this to override the default.
# RPC_URL=http://127.0.0.1:9000

# =============================================================================
# Package IDs (auto-populated by deploy-all for localnet)
# =============================================================================
# For localnet: leave empty — deploy-all writes these automatically.

# DeepBook package
# DEEPBOOK_PACKAGE_ID=

# DEEP token package
# DEEP_TOKEN_PACKAGE_ID=

# DEEP treasury object ID
# DEEP_TREASURY_ID=

# Margin trading package (optional)
# MARGIN_PACKAGE_ID=

# =============================================================================
# Market Maker (only needed if using docker market-maker service)
# =============================================================================
# Spread in basis points (default: 10 = 0.1%)
# MM_SPREAD_BPS=10

# Number of orders per side (default: 5)
# MM_LEVELS_PER_SIDE=5

# Order size in base asset units (default: 10_000_000 = 10 DEEP)
# MM_ORDER_SIZE_BASE=10000000

# Rebalance interval in milliseconds (default: 10000)
# MM_REBALANCE_INTERVAL_MS=10000

# Health check port inside container (default: 3000, mapped to host 3001)
# MM_HEALTH_CHECK_PORT=3000

# Prometheus metrics port inside container (default: 9090, mapped to host 9091)
# MM_METRICS_PORT=9090

# =============================================================================
# Docker Images (override to pin specific versions or registries)
# =============================================================================
# Each defaults to the latest published image. ARM64 tags use the -arm64 suffix.
# For x86_64, drop the -arm64 suffix (e.g. :89def920ad19a1a1a040b3df66cdd0d87e5300c2).
# MARKET_MAKER_IMAGE=mysten/deepbook-sandbox-market-maker:89def920ad19a1a1a040b3df66cdd0d87e5300c2-arm64
# INDEXER_IMAGE=mysten/deepbookv3-sandbox-indexer:794efb1c54ee5cc4f0f367233a4e70818aa0defb-arm64
# SERVER_IMAGE=mysten/deepbookv3-server:794efb1c54ee5cc4f0f367233a4e70818aa0defb-arm64
# FAUCET_IMAGE=mysten/deepbook-sandbox-faucet:89def920ad19a1a1a040b3df66cdd0d87e5300c2-arm64
# ORACLE_SERVICE_IMAGE=mysten/deepbook-sandbox-oracle-service:89def920ad19a1a1a040b3df66cdd0d87e5300c2-arm64

# =============================================================================
# Indexer Configuration (Optional)
# =============================================================================
# Starting checkpoint for indexer (omit to start from beginning)
# Useful for faster sync if you only need recent data
# FIRST_CHECKPOINT=

# Log level: trace, debug, info, warn, error
RUST_LOG=info

# =============================================================================
# Faucet Service (port 9009)
# =============================================================================
# Distributes SUI (proxied from Sui faucet) and DEEP tokens for testing.
# Uses the deployer's PRIVATE_KEY to sign DEEP transfers.
# DEEP_TOKEN_PACKAGE_ID is required to construct the DEEP coin type.
# RPC_URL is shared with the rest of the stack.

# =============================================================================
# Database (auto-configured by docker-compose, no need to set)
# =============================================================================
# DATABASE_URL=postgresql://postgres:postgres@postgres:5432/deepbook
