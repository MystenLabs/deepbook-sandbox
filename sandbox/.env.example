# DeepBook Sandbox Environment Variables
# Copy this file to .env and customize as needed
#
# Most defaults work out of the box for testnet.

# Private key for the deployer/signer (suiprivkey1... or 0x... hex).
# Required for deployment and pool creation.
PRIVATE_KEY=suiprivkey1qqlnlkrwvxwy43urjl0gv6ehynr2mk9esdq4kdvsppyw9da40vtguavdt90 

# =============================================================================
# Sui Localnet (only needed if using --profile localnet)
# =============================================================================
# Set based on your CPU architecture:
#   ARM64 (Apple Silicon M1/M2/M3/M4): mysten/sui-tools:compat-arm64
#   x86_64 (Intel/AMD):                mysten/sui-tools:compat
SUI_TOOLS_IMAGE=mysten/sui-tools:compat-arm64

# Wipe chain state on every restart (default: true)
# Set to empty to persist state across restarts
FORCE_REGENESIS=true

# =============================================================================
# Network Configuration
# =============================================================================
# Sui network: "testnet" or "mainnet"
NETWORK=testnet

# Sui RPC endpoint URL
RPC_URL=https://fullnode.testnet.sui.io:443

# =============================================================================
# Testnet Package IDs (defaults work out of the box)
# =============================================================================
# For official package IDs, see:
# https://docs.google.com/document/d/1uK4MNqYa0LdhVqBD4KqOcWG1N1nNNe3JwbeUZc1kH1I

# Latest testnet DeepBook package
DEEPBOOK_PACKAGE_ID=0x22be4cade64bf2d02412c7e8d0e8beea2f78828b948118d46735315409371a3c

# DEEP token package
DEEP_TOKEN_PACKAGE_ID=0xdeeb7a4662eec9f2f3def03fb937a663dddaa2e215b8078a284d026b7946c270

# DEEP treasury object ID
DEEP_TREASURY_ID=0x032abf8948dda67a271bcc18e776dbbcfb0d58c8d288a700ff0d5521e57a1ffe

# Margin trading package (optional - not yet on mainnet)
# MARGIN_PACKAGE_ID=

# =============================================================================
# Market Maker (only needed if using docker market-maker service)
# =============================================================================
# Spread in basis points (default: 10 = 0.1%)
# MM_SPREAD_BPS=10

# Number of orders per side (default: 5)
# MM_LEVELS_PER_SIDE=5

# Order size in base asset units (default: 10_000_000 = 10 DEEP)
# MM_ORDER_SIZE_BASE=10000000

# Rebalance interval in milliseconds (default: 10000)
# MM_REBALANCE_INTERVAL_MS=10000

# Health check port inside container (default: 3000, mapped to host 3001)
# MM_HEALTH_CHECK_PORT=3000

# Prometheus metrics port inside container (default: 9090, mapped to host 9091)
# MM_METRICS_PORT=9090

# =============================================================================
# Indexer Configuration (Optional)
# =============================================================================
# Starting checkpoint for indexer (omit to start from beginning)
# Useful for faster sync if you only need recent data
# FIRST_CHECKPOINT=

# Log level: trace, debug, info, warn, error
RUST_LOG=info

# =============================================================================
# Database (auto-configured by docker-compose, no need to set)
# =============================================================================
# DATABASE_URL=postgresql://postgres:postgres@postgres:5432/deepbook
