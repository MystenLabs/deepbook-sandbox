{
	"name": "@mysten-incubation/create-deepbook-sandbox",
	"version": "0.1.1",
	"description": "Scaffold a DeepBook V3 sandbox workspace",
	"author": "Mysten Labs <build@mystenlabs.com>",
	"license": "Apache-2.0",
	"homepage": "https://github.com/MystenLabs/deepbook-sandbox/tree/main/packages/create-deepbook-sandbox#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/MystenLabs/deepbook-sandbox.git"
	},
	"bugs": {
		"url": "https://github.com/MystenLabs/deepbook-sandbox/issues"
	},
	"keywords": [
		"sui",
		"deepbook",
		"clob",
		"sandbox",
		"scaffold",
		"web3"
	],
	"type": "module",
	"packageManager": "pnpm@10.17.0",
	"engines": {
		"node": ">=18"
	},
	"bin": "./bin/index.js",
	"scripts": {
		"clean": "rm -rf tsconfig.tsbuildinfo ./dist",
		"build": "tsc --build",
		"prettier:check": "prettier -c --ignore-unknown .",
		"prettier:fix": "prettier -w --ignore-unknown .",
		"oxlint:check": "oxlint .",
		"oxlint:fix": "oxlint --fix",
		"lint": "pnpm run oxlint:check && pnpm run prettier:check",
		"lint:fix": "pnpm run oxlint:fix && pnpm run prettier:fix"
	},
	"files": [
		"CHANGELOG.md",
		"README.md",
		"bin",
		"dist",
		"src"
	],
	"publishConfig": {
		"access": "public"
	},
	"sideEffects": false,
	"devDependencies": {
		"@ianvs/prettier-plugin-sort-imports": "^4.7.0",
		"@types/node": "^20.19.32",
		"oxlint": "^1.39.0",
		"prettier": "^3.7.4",
		"typescript": "^5.9.3"
	}
}
